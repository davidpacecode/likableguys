<div id="<%= dom_id race %>">
  <p>
    <strong>Event:</strong>
    <%= race.event %>
  </p>

  <p>
    <strong>Event no:</strong>
    <%= race.event_no %>
  </p>

  <p>
    <strong>Age group:</strong>
    <%= race.age_group %>
  </p>

  <p>
    <strong>Course:</strong>
    <%= race.course %>
  </p>

  <p>
    <strong>Heat:</strong>
    <%= race.heat %>
  </p>

  <p>
    <strong>Lane:</strong>
    <%= race.lane %>
  </p>

  <p>
    <strong>Seed time:</strong>
    <%= race.seed_time %>
  </p>

  <p>
    <strong>Final time:</strong>
    <%= race.final_time %>
  </p>

  <p>
    <strong>Race date:</strong>
    <%= race.race_date %>
  </p>

  <p>
    <strong>Swim meet:</strong>
    <%= race.swim_meet_id %>
  </p>

</div>
