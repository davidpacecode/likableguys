<div id="<%= dom_id swim_meet %>">
  <p>
    <strong>Name:</strong>
    <%= swim_meet.name %>
  </p>

  <p>
    <strong>Location:</strong>
    <%= swim_meet.location %>
  </p>

  <p>
    <strong>Address:</strong>
    <%= swim_meet.address %>
  </p>

  <p>
    <strong>Url:</strong>
    <%= swim_meet.url %>
  </p>

  <p>
    <strong>Start date:</strong>
    <%= swim_meet.start_date %>
  </p>

  <p>
    <strong>End date:</strong>
    <%= swim_meet.end_date %>
  </p>

  <p>
    <strong>Description:</strong>
    <%= swim_meet.description %>
  </p>

</div>
